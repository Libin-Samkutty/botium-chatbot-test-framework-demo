      "WHATSAPP_RECIPIENT_NUMBER": "${{WA_RECIPIENT_NUMBER}}",
      "SCRIPTING_ENABLE_MEMORY": true,
      "CUSTOMHOOK_ONBUILD": "./auth.js"
    }
  }
}
