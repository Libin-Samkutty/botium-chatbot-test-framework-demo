# Healthcare Assistant Bot - Configuration
# Copy this file to .env and fill in your actual values before running tests

# Healthcare bot API endpoints
BOT_WEBHOOK_URL=https://healthcare-api.example.com/facebook/staging/webhook
WA_WEBHOOK_URL=https://healthcare-api.example.com/whatsapp/webhook?env=staging

# Facebook Messenger configuration
FB_PAGE_ID=your_healthcare_page_id
FB_APP_SECRET=your_fb_app_secret

# WhatsApp configuration
WA_RECIPIENT_NUMBER=+11234567890
WA_WEBHOOK_SECRET=your_wa_webhook_secret

# Redis inbound proxy (required for webhook-based testing)
REDIS_URL=redis://localhost:6379

# AWS Configuration (optional - for production secret management)
AWS_REGION=us-east-1
AWS_SSM_SECRET_PATH=/healthcare/staging/credentials

# Development/Testing
NODE_ENV=demo-stage-wa
DEBUG=botium:*
